# NOTSY Environment Variables
# Copy this file to .env and fill in your values

# Groq API Configuration (required for AI agents)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3-70b-8192

# Database Configuration
POSTGRES_PASSWORD=notsy

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Redis Configuration (optional - defaults provided)
REDIS_URL=redis://localhost:6379

# ChromaDB Configuration (optional - defaults provided)
CHROMA_URL=http://localhost:8000
CHROMA_PERSIST_DIR=./chroma_db

# Upload Directory Configuration
UPLOAD_BASE_DIR=./uploads

# Spring Boot Configuration
SPRING_BOOT_CALLBACK_URL=http://localhost:8080

# Feature Flags
ENABLE_SELF_RAG=true